<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.mapper.EmployeeTransferMapper">

    <resultMap id="BaseResultMap" type="com.hrms.entity.EmployeeTransfer">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="transfer_type" property="transferType"/>
        <result column="business_id" property="businessId"/>
        <result column="before_data" property="beforeData"/>
        <result column="after_data" property="afterData"/>
        <result column="effective_date" property="effectiveDate"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="VOResultMap" type="com.hrms.vo.EmployeeTransferVO">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="transfer_type" property="transferType"/>
        <result column="business_id" property="businessId"/>
        <result column="before_data" property="beforeData"/>
        <result column="after_data" property="afterData"/>
        <result column="effective_date" property="effectiveDate"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.hrms.entity.EmployeeTransfer"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO employee_transfer
        (employee_id, transfer_type, business_id, before_data, after_data, effective_date, remark)
        VALUES
        (#{employeeId}, #{transferType}, #{businessId}, #{beforeData}, #{afterData}, #{effectiveDate}, #{remark})
    </insert>

    <select id="selectByEmployee" resultMap="VOResultMap">
        SELECT * FROM employee_transfer
        WHERE employee_id = #{employeeId}
        <if test="transferType != null">AND transfer_type = #{transferType}</if>
        ORDER BY create_time DESC
    </select>

</mapper>
