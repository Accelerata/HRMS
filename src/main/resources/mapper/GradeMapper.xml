<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.mapper.GradeMapper">

    <resultMap id="BaseResultMap" type="com.hrms.entity.Grade">
        <id column="id" property="id"/>
        <result column="sequence" property="sequence"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="level_order" property="levelOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM grade
        WHERE status = 1
        ORDER BY FIELD(`sequence`, 'M', 'P', 'S'), level_order ASC
    </select>

    <select id="selectBySequence" resultMap="BaseResultMap">
        SELECT * FROM grade
        WHERE `sequence` = #{sequence} AND status = 1
        ORDER BY level_order ASC
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM grade WHERE code = #{code}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM grade WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO grade (`sequence`, code, name, level_order, status, create_time, update_time)
        VALUES (#{sequence}, #{code}, #{name}, #{levelOrder}, #{status}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE grade
        SET `sequence`  = #{sequence},
            code        = #{code},
            name        = #{name},
            level_order = #{levelOrder},
            status      = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM grade WHERE id = #{id}
    </delete>

</mapper>
