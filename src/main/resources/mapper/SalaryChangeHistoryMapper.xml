<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.mapper.SalaryChangeHistoryMapper">

    <resultMap id="BaseResultMap" type="com.hrms.entity.SalaryChangeHistory">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="account_id" property="accountId"/>
        <result column="change_type" property="changeType"/>
        <result column="field_name" property="fieldName"/>
        <result column="old_value" property="oldValue"/>
        <result column="new_value" property="newValue"/>
        <result column="change_reason" property="changeReason"/>
        <result column="source_business" property="sourceBusiness"/>
        <result column="operator_id" property="operatorId"/>
        <result column="encryption_version" property="encryptionVersion"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO salary_change_history (employee_id, account_id, change_type, field_name, old_value, new_value,
            change_reason, source_business, operator_id, encryption_version, create_time)
        VALUES (#{employeeId}, #{accountId}, #{changeType}, #{fieldName}, #{oldValue}, #{newValue},
            #{changeReason}, #{sourceBusiness}, #{operatorId}, 1, NOW())
    </insert>

    <select id="selectByEmployeeId" resultMap="BaseResultMap">
        SELECT * FROM salary_change_history WHERE employee_id = #{employeeId} ORDER BY create_time DESC
    </select>

    <select id="selectByAccountId" resultMap="BaseResultMap">
        SELECT * FROM salary_change_history WHERE account_id = #{accountId} ORDER BY create_time DESC
    </select>

</mapper>
