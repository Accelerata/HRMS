<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.mapper.PayslipViewLogMapper">

    <resultMap id="BaseResultMap" type="com.hrms.entity.PayslipViewLog">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="record_id" property="recordId"/>
        <result column="verify_method" property="verifyMethod"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="user_agent" property="userAgent"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO payslip_view_log (employee_id, record_id, verify_method, ip_address, user_agent, create_time)
        VALUES (#{employeeId}, #{recordId}, #{verifyMethod}, #{ipAddress}, #{userAgent}, NOW())
    </insert>

    <select id="selectByEmployeeAndRecord" resultMap="BaseResultMap">
        SELECT * FROM payslip_view_log WHERE employee_id = #{employeeId} AND record_id = #{recordId}
    </select>

</mapper>
